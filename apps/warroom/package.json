{
  "name": "@ppo-smc/warroom",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.20 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=line",
    "gen:api": "openapi-typescript ../../specs/006-spring-gateway/contracts/openapi.yaml -o src/api/types.gen.ts",
    "gen:openapi": "openapi-typescript ../../specs/006-spring-gateway/contracts/openapi.yaml -o src/api/types.gen.ts",
    "gen:check": "node -e \"if(!require('fs').existsSync('src/api/types.gen.ts')) process.exit(1)\"",
    "i18n:check": "node scripts/i18n-check.cjs",
    "lighthouse": "lhci autorun || echo 'lhci not configured (T095 placeholder)'",
    "bundle:check": "node scripts/bundle-check.cjs",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.40.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^7.2.1",
    "lightweight-charts": "^4.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.8",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.5",
    "msw": "^2.3.0",
    "openapi-typescript": "^7.0.0-next.10",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
