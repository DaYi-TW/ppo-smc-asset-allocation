# 戰情室前端環境變數範例（檔次 2-local：單機 docker-compose 論文展示版）
# 複製為 .env.local 後依本機環境調整。

# 是否啟用 MSW mock（true 時不打 real backend）。
# Phase 2 Foundational 階段預設 true；Phase 3 US1 完成後可切 false 接 006。
VITE_USE_MOCK=true

# 後端 API base URL（006 Spring Gateway，未來 docker-compose 內為 http://gateway:8080）
VITE_API_BASE_URL=http://localhost:8080

# 後端 SSE base URL（同上，可分離測試環境）
VITE_SSE_BASE_URL=http://localhost:8080

# === 以下為 [SCOPE-REDUCED] 檔次 3 雲端部署才會用到 ===
# JWT auth provider URL（FR-013–FR-015，本檔次不啟用）
# VITE_AUTH_PROVIDER_URL=
# Demo JWT 直接注入（dev only），檔次 2 不需要
# VITE_DEMO_JWT=
