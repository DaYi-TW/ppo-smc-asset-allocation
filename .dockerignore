# Keep build context lean. Most of the repo is bind-mounted at runtime, so we
# don't need to ship it into the image layers — only the dependency manifests
# (pyproject.toml, requirements-lock.txt) need to be available during build.

# VCS
.git/
.gitignore
.github/

# Local env / secrets — must never enter the image
.env
.env.*
!.env.example

# Python build / cache artifacts
__pycache__/
*.py[cod]
*.so
*.egg-info/
build/
dist/
.eggs/
.venv/
venv/

# Test / type / lint caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/
.hypothesis/

# Data — bind-mounted at runtime for 002 dev image. 005 inference image needs
# data/raw committed into the image (immutable artefact, FR-013/014); keep that
# subdir but skip staging dirs that may linger on disk.
data/
!data/raw/
data/staging/
data/snapshots/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Spec Kit artefacts — not needed inside the runtime image
specs/
docs/
mockups/
.specify/
.claude/

# Misc
*.log
README.md
CLAUDE.md
